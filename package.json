{
  "name": "domo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tableau de bord énergie de la maison Feroux",
  "author": "Laurent Feroux",
  "license": "MIT",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "test:cumulus": "node --experimental-strip-types --test scripts/cumulus-decide.test.ts",
    "test:energy": "node --experimental-strip-types --test scripts/cumulus-energy.test.ts",
    "test:plan": "node --experimental-strip-types --test scripts/cumulus-plan.test.ts",
    "test:atomic": "node --experimental-strip-types --test scripts/atomic-store.test.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^22.10.0",
    "@types/three": "^0.184.1",
    "@types/web-push": "^3.6.4",
    "@vite-pwa/sveltekit": "^1.1.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@threlte/core": "^8.5.16",
    "@threlte/extras": "^9.21.0",
    "better-sqlite3": "^12.10.0",
    "d3-scale": "^4.0.0",
    "d3-shape": "^3.2.0",
    "layercake": "^8.4.0",
    "mqtt": "^5.15.1",
    "three": "^0.184.0",
    "web-push": "^3.6.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
