# Pas de variables nécessaires en Phase 1.1 (données mockées).
# Les variables HA seront ajoutées en Phase 1.4.

# Phase 1.4 (à venir) :
# PUBLIC_HA_URL=https://maison.feroux.fr

# Solcast — prévisions PV (proxy serveur, jamais exposé au navigateur)
SOLCAST_API_KEY=your_solcast_api_key_here
SOLCAST_RESOURCE_ID=your_solcast_resource_id_here

# ═══════════════════════════════════════════════════════
# MQTT — Zigbee2MQTT via WebSocket (PUBLIC : exposé au browser)
# ═══════════════════════════════════════════════════════
# Le broker mosquitto du RPi4 est tunnelisé jusqu'au VPS sur :9001 et
# proxié en WSS via Caddy (/mqtt/). Credentials nécessaires (allow_anonymous false).
PUBLIC_MQTT_WS_URL=wss://domo.feroux.fr/mqtt/
PUBLIC_MQTT_USER=ha_user
PUBLIC_MQTT_PASSWORD=your_mqtt_password_here

# ═══════════════════════════════════════════════════════
# Portail — endpoint serveur POST /api/portail/pulse (raccourci iPhone)
# ═══════════════════════════════════════════════════════
# Listener MQTT local lu côté serveur (mosquitto WS tunnelisé). Défaut si absent :
# ws://127.0.0.1:9001. Évite le détour public wss://domo.feroux.fr/mqtt/.
MQTT_INTERNAL_URL=ws://127.0.0.1:9001
# Token d'auth de l'endpoint (en-tête Authorization: Bearer <token>). PRIVÉ.
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
PORTAIL_TOKEN=your_portail_token_here

# ═══════════════════════════════════════════════════════
# Anker bridge — endpoint REST proxié par Caddy
# ═══════════════════════════════════════════════════════
PUBLIC_ANKER_URL=https://domo.feroux.fr/anker

# ═══════════════════════════════════════════════════════
# Auth magic link
# ═══════════════════════════════════════════════════════
# Token du magic link (généré automatiquement par add-auth-domo.sh)
# Lien d'accès : https://domo.feroux.fr/auth?k=<AUTH_TOKEN>
AUTH_TOKEN=changeme_openssl_rand_hex_32

# Clé secrète pour signer les cookies (ne pas partager)
AUTH_SECRET=changeme_openssl_rand_hex_32

# forecast-bridge — prévision PV (Open-Meteo + PVLib, RPi4) ; proxy server-side /api/forecast
FORECAST_BRIDGE_URL=http://127.0.0.1:8098

# thermostat-bridge — régulation sèche-serviette SdB (TPI, RPi4) ; proxy server-side /api/thermostat.
# Daemon en loopback via tunnel SSH inverse. Absent = thermostat affiché « hors ligne ».
THERMOSTAT_BRIDGE_URL=http://127.0.0.1:8101

# ═══════════════════════════════════════════════════════
# EM-50 — compteur Shelly Pro EM-50 (réseau EDF + conso cumulus), proxy /api/em50/status
# ═══════════════════════════════════════════════════════
# Tunnel SSH inverse RPi4 :8102 → 192.168.1.54. Mapping des voies figé à l'install
# (voies non nommées) : 0 = réseau (act_power signé), 1 = cumulus. SIGN=-1 si pince inversée.
EM50_URL=http://127.0.0.1:8102
EM50_GRID_ID=0
EM50_CUMULUS_ID=1
EM50_GRID_SIGN=1

# ═══════════════════════════════════════════════════════
# Orchestrateur cumulus — endpoint POST /api/cumulus/tick (timer systemd 60 s)
# ═══════════════════════════════════════════════════════
# Le timer domo-cumulus.timer déclenche le moteur de chauffe via curl localhost
# SANS cookie : auth par token (Authorization: Bearer <token>). PRIVÉ.
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CUMULUS_TICK_TOKEN=your_cumulus_tick_token_here
