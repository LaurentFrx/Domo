# thermostat-bridge — configuration (à déployer sur le RPi4)
THERMOSTAT_HTTP_HOST=127.0.0.1
THERMOSTAT_HTTP_PORT=8101

# python-matter-server (WebSocket) — cf. getMatterWsUrl() côté Domo
MATTER_WS_URL=ws://192.168.1.29:5580/ws
MATTER_NODE_ID=1

# Broker mosquitto local (RPi4)
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TRANSPORT=tcp
MQTT_USER=ha_user
MQTT_PASSWORD=changeme

# Topics sondes Zigbee (attention à l'espace dans « Thermo SdB »)
THERMOSTAT_SENSOR_TOPIC=zigbee2mqtt/Thermo SdB
THERMOSTAT_OUTDOOR_TOPIC=zigbee2mqtt/Thermo_ext

# Repli sûr si la sonde se tait (s)
THERMOSTAT_SENSOR_TIMEOUT_SEC=1800
